{
  "name": "all-ok",
  "version": "0.3.3",
  "description": "Validate anything simply and type-safely",
  "keywords": [
    "validation",
    "type-safe",
    "typescript"
  ],
  "author": "oreshinya",
  "license": "MIT",
  "repository": "oreshinya/all-ok",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "docsgen": "typedoc",
    "typecheck": "tsc",
    "lint": "biome ci ./src",
    "lintfix": "biome check --write ./src",
    "test": "vitest run",
    "build": "tsup"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "tsup": "^8.3.5",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typescript": "^6.0.2",
    "valibot": "^1.3.1",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0+sha512.EFaLtKavtYyes2MNqQzJUWQXq+vT+rvmc58K55VyjaFJHp21pUTHatjrdXD1xLs9bGN7LLQb/c20f6gjyGSTGQ=="
}
